<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof metaTitle !== 'undefined' ? metaTitle : (typeof title !== 'undefined' ? title : 'SheenClassics — Premium Embroidered Clothing') %>
    </title>
    <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : '' %>">
    <meta name="keywords" content="<%= typeof metaKeywords !== 'undefined' ? metaKeywords : '' %>">
    <meta name="robots" content="<%= typeof metaRobots !== 'undefined' ? metaRobots : 'index, follow' %>">
    <link rel="canonical" href="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : '' %>">

    <meta property="og:title" content="<%= typeof ogTitle !== 'undefined' ? ogTitle : (typeof metaTitle !== 'undefined' ? metaTitle : '') %>">
    <meta property="og:description" content="<%= typeof ogDescription !== 'undefined' ? ogDescription : (typeof metaDescription !== 'undefined' ? metaDescription : '') %>">
    <meta property="og:image" content="<%= typeof ogImage !== 'undefined' ? ogImage : '' %>">
    <meta property="og:url" content="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : '' %>">
    <meta property="og:type" content="<%= typeof ogType !== 'undefined' ? ogType : 'website' %>">
    <meta property="og:site_name" content="SheenClassics">
    <meta property="og:locale" content="en_US">
    <meta name="twitter:card" content="<%= typeof twitterCard !== 'undefined' ? twitterCard : 'summary_large_image' %>">
    <meta name="twitter:title" content="<%= typeof ogTitle !== 'undefined' ? ogTitle : (typeof metaTitle !== 'undefined' ? metaTitle : '') %>">
    <meta name="twitter:description" content="<%= typeof ogDescription !== 'undefined' ? ogDescription : (typeof metaDescription !== 'undefined' ? metaDescription : '') %>">
    <meta name="twitter:image" content="<%= typeof ogImage !== 'undefined' ? ogImage : '' %>">
    <meta name="theme-color" content="#ffffff">

    <% if (typeof structuredData !== 'undefined' && structuredData) { %>
        <script type="application/ld+json"><%- JSON.stringify(structuredData) %></script>
    <% } %>

    <link rel="stylesheet" href="/css/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>

<body>

    <!-- ── Announcement Bar ── -->
    <div style="background:var(--primary);color:rgba(255,255,255,0.75);text-align:center;padding:0.5rem 1rem;font-size:0.72rem;letter-spacing:0.12em;text-transform:uppercase;font-weight:500;border-bottom:1px solid rgba(212,175,55,0.2);">
        <span style="color:var(--gold);">✦</span> &nbsp; Free nationwide delivery on orders over Rs 3,000 &nbsp;
        <span style="color:var(--gold);">✦</span>
    </div>

    <!-- ── Navigation ── -->
    <nav class="navbar" id="main-navbar">
        <div class="container">
            <div class="nav-wrapper">

                <!-- Logo -->
                <a href="/" class="logo" aria-label="SheenClassics home">
                    <img src="/images/logoc.jpg" alt="SheenClassics">
                </a>

                <!-- Desktop Menu -->
                <ul class="nav-menu" id="nav-menu">
                    <li><a href="/" class="nav-link">Home</a></li>
                    <li><a href="/products?category=Clothing" class="nav-link">Clothing</a></li>
                    <li><a href="/products?category=HomeDecor" class="nav-link">Home Decor</a></li>
                    <li><a href="/account" class="nav-link">Account</a></li>

                    <% if (typeof session !== 'undefined' && session.userId) { %>

                        <% if (session.isAdmin) { %>
                            <li>
                                <a href="/admin/dashboard" class="nav-link admin-link" style="display:flex;align-items:center;gap:4px;">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>                                    Admin
                                </a>
                            </li>
                            <li class="admin-stock-alerts" id="admin-stock-alerts">
                                <button type="button" class="admin-stock-alerts-btn" id="admin-stock-alerts-btn" title="Stock notifications" aria-label="Stock notifications" aria-expanded="false">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 7-3 7h18s-3 0-3-7"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                                    <span class="admin-stock-alerts-count" id="admin-stock-alerts-count" hidden>0</span>
                                </button>
                                <div class="admin-stock-alerts-panel" id="admin-stock-alerts-panel" hidden>
                                    <div class="admin-stock-alerts-title">Stock Alerts</div>
                                    <div class="admin-stock-alerts-list" id="admin-stock-alerts-list">
                                        <p class="admin-stock-alerts-empty">Checking inventory...</p>
                                    </div>
                                    <a class="admin-stock-alerts-link" href="/admin/products">View all products</a>
                                </div>
                            </li>
                            <% } %>


                                <!-- Cart & Wishlist icons (large screens only) -->
                                <li class="nav-icons-lg" style="display:flex;align-items:center;gap:10px;">
                                    <a href="/account?tab=cart" class="nav-icon-link" title="Cart" style="display:inline-flex;align-items:center;">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:2px;"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h7.72a2 2 0 0 0 2-1.61l1.38-7.39H6"/></svg>
                                    </a>
                                    <a href="/account?tab=wishlist" class="nav-icon-link" title="Wishlist" style="display:inline-flex;align-items:center;">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                                    </a>
                                </li>

                                <li>
                                    <a href="/auth/logout" class="nav-link" onclick="event.preventDefault(); document.getElementById('logout-form').submit();" style="display:flex;align-items:center;gap:4px;color:var(--text-muted);">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>                                        Logout
                                    </a>
                                    <form id="logout-form" action="/auth/logout" method="POST" style="display:none;"></form>
                                </li>

                                <% } else { %>
                                    <li><a href="/auth/login" class="nav-link">Login</a></li>
                                    <li><a href="/auth/signup" class="nav-link btn-primary">Sign Up</a></li>
                                    <% } %>

                </ul>

                <!-- Mobile toggle -->
                <button class="mobile-menu-toggle" id="mobile-toggle" aria-label="Toggle menu" aria-expanded="false">
                <span></span>
                <span></span>
                <span></span>
            </button>
            </div>
        </div>
    </nav>

    <style>
        /* Show nav-icons-lg only on large screens */
        
        .nav-icons-lg {
            display: none !important;
        }
        
        @media (min-width: 992px) {
            .nav-icons-lg {
                display: flex !important;
            }
            .nav-icon-link svg {
                opacity: 0.8;
                transition: opacity 0.2s;
            }
            .nav-icon-link:hover svg {
                opacity: 1;
            }
        }

        .admin-stock-alerts {
            position: relative;
        }

        .admin-stock-alerts-btn {
            width: 34px;
            height: 34px;
            border: 1px solid var(--border);
            background: var(--surface);
            color: var(--text-secondary);
            border-radius: var(--radius-sm);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .admin-stock-alerts-count {
            position: absolute;
            top: -6px;
            right: -6px;
            min-width: 18px;
            height: 18px;
            border-radius: 99px;
            background: #c0392b;
            color: #fff;
            font-size: 0.65rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0 5px;
        }

        .admin-stock-alerts-panel {
            position: absolute;
            right: 0;
            top: calc(100% + 10px);
            width: min(340px, 86vw);
            background: #fff;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow-md);
            z-index: 1100;
            overflow: hidden;
        }

        .admin-stock-alerts-title {
            padding: 0.9rem 1rem;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            border-bottom: 1px solid var(--border);
        }

        .admin-stock-alerts-item,
        .admin-stock-alerts-empty {
            margin: 0;
            padding: 0.85rem 1rem;
            font-size: 0.82rem;
            color: var(--text-secondary);
            border-bottom: 1px solid var(--border);
        }

        .admin-stock-alerts-item.critical {
            background: #fff5f5;
            color: #a93226;
        }

        .admin-stock-alerts-item.warning {
            background: #fffbeb;
            color: #8a5a00;
        }

        .admin-stock-alerts-link {
            display: block;
            padding: 0.75rem 1rem;
            text-align: center;
            color: var(--gold);
            font-size: 0.78rem;
            font-weight: 700;
        }
    </style>
    <!-- Mobile nav overlay -->
    <div class="nav-overlay" id="nav-overlay"></div>

    <!-- ── Toast Notification ── -->
    <div id="notification" style="display:none;position:fixed;top:88px;right:20px;z-index:9999;max-width:320px;min-width:240px;padding:1rem 1.25rem;border-radius:var(--radius-lg);box-shadow:var(--shadow-lg);font-size:0.85rem;font-weight:500;font-family:var(--font-body);display:flex;align-items:center;gap:0.6rem;transition:all 0.3s var(--ease);">
    </div>
