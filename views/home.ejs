<%- include('partials/header') %>

    <main>
        <!-- ===========================
         HERO SECTION
         =========================== -->
        <section class="hero">
            <div class="hero-bg"></div>
            <div class="hero-overlay"></div>
            <div class="hero-deco"></div>

            <div class="container">
                <div class="hero-content">
                    <p class="hero-eyebrow">Handcrafted with Excellence</p>
                    <h1>Sheen<em>Classics</em></h1>
                    <p>Premium embroidered clothing for the modern connoisseur — where heritage meets contemporary elegance.</p>
                    <div class="hero-actions">
                        <a href="/products" class="hero-btn">
                            <span>Explore Collection</span>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </a>
                        <a href="#featured" class="hero-btn-outline">Featured Pieces</a>
                    </div>
                </div>
            </div>

            <div class="hero-scroll">
                <div class="hero-scroll-line"></div>
                <span>Scroll</span>
            </div>
        </section>

        <!-- ===========================
         FEATURED PRODUCTS
         =========================== -->
        <% if (featuredProducts && featuredProducts.length > 0) { %>
            <section class="section" id="featured">
                <div class="container">
                    <div class="section-header reveal">
                        <span class="section-eyebrow">Curated for You</span>
                        <h2 class="section-title">Featured <em>Pieces</em></h2>
                        <div class="section-divider"></div>
                    </div>

                    <div class="product-grid">
                        <% featuredProducts.forEach((product, i) => { %>
                            <div class="product-card reveal reveal-delay-<%= Math.min(i % 4 + 1, 4) %>" onclick="window.location.href='/products/<%= product.slug || product._id %>'">

                                <div class="product-image-wrap">
                                    <img src="<%= product.images && product.images[0] ? product.images[0] : '/images/p1.jpeg' %>" alt="<%= product.name %>" class="product-image" loading="lazy">

                                    <% if (product.originalPrice && product.originalPrice > product.price) { %>
                                        <span class="product-badge sale">Sale</span>
                                        <% } else { %>
                                            <span class="product-badge">Featured</span>
                                            <% } %>

                                </div>

                                <div class="product-info">
                                    <p class="product-category">
                                        <%= product.category || 'Collection' %>
                                    </p>
                                    <h3 class="product-name">
                                        <%= product.name %>
                                    </h3>

                                    <div class="product-price-row">
                                        <div class="product-price">
                                            Rs
                                            <%= product.price.toFixed(2) %>
                                                <% if (product.originalPrice && product.originalPrice > product.price) { %>
                                                    <span class="original">Rs <%= product.originalPrice.toFixed(2) %></span>
                                                    <% } %>
                                        </div>
                                    </div>

                                    <div class="product-actions">
                                        <button class="btn btn-add-cart" data-product-id="<%= product._id %>">
                                <span>Add to Cart</span>
                            </button>
                                        <button class="btn btn-wishlist" data-product-id="<%= product._id %>" title="Add to Wishlist">♡</button>
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                    </div>

                    <div style="text-align:center; margin-top: 3rem;" class="reveal">
                        <a href="/products" class="btn btn-add-cart" style="display:inline-flex; padding: 0.85rem 2.5rem;">
                            <span>View All Products</span>
                        </a>
                    </div>
                </div>
            </section>
            <% } %>

                <!-- ===========================
         BLOGS
         =========================== -->
                <section class="blog-section">
                    <div class="container">
                        <div class="section-header reveal" style="margin-bottom:2.5rem;">
                            <span class="section-eyebrow">Style Notes</span>
                            <h2 class="section-title">From the <em>Journal</em></h2>
                            <div class="section-divider"></div>
                        </div>

                        <div class="blog-carousel reveal" id="blog-carousel">
                            <button type="button" class="blog-nav blog-nav-prev" aria-label="Previous blog">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
                            </button>
                            <div class="blog-track" id="blog-track">
                                <% const fallbackBlogs = [
                                    { category: 'Embroidery Guide', title: 'How to Style Embroidered Pieces for Everyday Wear', excerpt: 'Classic embroidery can feel effortless with the right pairings. Build looks around clean silhouettes, balanced color, and one standout detail.' },
                                    { category: 'Care Notes', title: 'Keeping Premium Fabrics Fresh Longer', excerpt: 'Gentle washing, shade drying, and careful storage protect fabric texture and threadwork so your favorites stay beautiful season after season.' },
                                    { category: 'Buying Guide', title: 'Choosing Occasion Wear That Still Feels Comfortable', excerpt: 'Look for breathable fabrics, thoughtful details, and versatile colors that move naturally from family gatherings to formal evenings.' }
                                ]; %>
                                <% const visibleBlogs = blogs && blogs.length ? blogs : fallbackBlogs; %>
                                <% visibleBlogs.forEach(function(blog) { %>
                                    <article class="blog-card">
                                        <p class="blog-meta"><%= blog.category || 'Style Notes' %></p>
                                        <h3><%= blog.title %></h3>
                                        <p><%= blog.excerpt || (blog.content ? blog.content.replace(/[#*_`>-]/g, '').slice(0, 180) : '') %></p>
                                        <a href="<%= blog.slug ? '/blogs/' + blog.slug : '/products' %>" class="blog-link"><%= blog.slug ? 'Read article' : 'Explore pieces' %></a>
                                    </article>
                                <% }); %>
                            </div>
                            <button type="button" class="blog-nav blog-nav-next" aria-label="Next blog">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
                            </button>
                            <div class="blog-dots" id="blog-dots" aria-label="Blog carousel pagination"></div>
                        </div>
                    </div>
                </section>

                <!-- ===========================
         NEW ARRIVALS
         =========================== -->
                <% if (newProducts && newProducts.length > 0) { %>
                    <section class="section">
                        <div class="container">
                            <div class="section-header reveal">
                                <span class="section-eyebrow">Just In</span>
                                <h2 class="section-title">New <em>Arrivals</em></h2>
                                <div class="section-divider"></div>
                            </div>

                            <div class="product-grid">
                                <% newProducts.forEach((product, i) => { %>
                                    <div class="product-card reveal reveal-delay-<%= Math.min(i % 4 + 1, 4) %>" onclick="window.location.href='/products/<%= product._id %>'">

                                        <div class="product-image-wrap">
                                            <img src="<%= product.images && product.images[0] ? product.images[0] : '/images/p1.jpeg' %>" alt="<%= product.name %>" class="product-image" loading="lazy">
                                            <span class="product-badge">New</span>

                                        </div>

                                        <div class="product-info">
                                            <p class="product-category">
                                                <%= product.category || 'New Arrival' %>
                                            </p>
                                            <h3 class="product-name">
                                                <%= product.name %>
                                            </h3>

                                            <div class="product-price-row">
                                                <div class="product-price">
                                                    Rs
                                                    <%= product.price.toFixed(2) %>
                                                        <% if (product.originalPrice && product.originalPrice > product.price) { %>
                                                            <span class="original">Rs <%= product.originalPrice.toFixed(2) %></span>
                                                            <% } %>
                                                </div>
                                            </div>

                                            <div class="product-actions">
                                                <button class="btn btn-add-cart" data-product-id="<%= product._id %>">
                                <span>Add to Cart</span>
                            </button>
                                                <button class="btn btn-wishlist" data-product-id="<%= product._id %>" title="Add to Wishlist">♡</button>
                                            </div>
                                        </div>
                                    </div>
                                    <% }); %>
                            </div>
                        </div>
                    </section>
                    <% } %>

                        <!-- ===========================
         VALUE PILLARS
         =========================== -->
                        <section class="section" style="background: var(--primary); color: #fff; margin-top: 4rem;">
                            <div class="container">
                                <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap:3rem; text-align:center;">
                                    <div class="reveal">
                                        <div style="font-size:2rem; margin-bottom:1rem; color: var(--gold);">✦</div>
                                        <h3 style="font-family: var(--font-serif); font-size:1.3rem; font-weight:400; margin-bottom:0.5rem;">Handcrafted</h3>
                                        <p style="font-size:0.85rem; color:rgba(255,255,255,0.5); line-height:1.7;">Each piece embroidered with meticulous care and traditional artisan techniques.</p>
                                    </div>
                                    <div class="reveal reveal-delay-2">
                                        <div style="font-size:2rem; margin-bottom:1rem; color: var(--gold);">✦</div>
                                        <h3 style="font-family: var(--font-serif); font-size:1.3rem; font-weight:400; margin-bottom:0.5rem;">Premium Quality</h3>
                                        <p style="font-size:0.85rem; color:rgba(255,255,255,0.5); line-height:1.7;">Sourced from the finest fabrics, built to last and look exceptional.</p>
                                    </div>
                                    <div class="reveal reveal-delay-3">
                                        <div style="font-size:2rem; margin-bottom:1rem; color: var(--gold);">✦</div>
                                        <h3 style="font-family: var(--font-serif); font-size:1.3rem; font-weight:400; margin-bottom:0.5rem;">Timeless Design</h3>
                                        <p style="font-size:0.85rem; color:rgba(255,255,255,0.5); line-height:1.7;">Classic aesthetics with a modern edge — pieces that transcend seasons.</p>
                                    </div>
                                    <div class="reveal reveal-delay-4">
                                        <div style="font-size:2rem; margin-bottom:1rem; color: var(--gold);">✦</div>
                                        <h3 style="font-family: var(--font-serif); font-size:1.3rem; font-weight:400; margin-bottom:0.5rem;">Swift Delivery</h3>
                                        <p style="font-size:0.85rem; color:rgba(255,255,255,0.5); line-height:1.7;">Nationwide delivery with care, so your order arrives in perfect condition.</p>
                                    </div>
                                </div>
                            </div>
                        </section>
    </main>

    <!-- Scroll reveal + nav scroll script -->
    <script>
        // ── Scroll-reveal
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    e.target.classList.add('visible');
                    revealObserver.unobserve(e.target);
                }
            });
        }, {
            threshold: 0.1,
            rootMargin: '0px 0px -40px 0px'
        });

        document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

        // ── Mobile menu
        const toggle = document.querySelector('.mobile-menu-toggle');
        const menu = document.querySelector('.nav-menu');
        const overlay = document.querySelector('.nav-overlay');

        if (toggle && menu) {
            function toggleMenu(open) {
                toggle.classList.toggle('open', open);
                menu.classList.toggle('active', open);
                overlay && overlay.classList.toggle('active', open);
                document.body.style.overflow = open ? 'hidden' : '';
            }

            toggle.addEventListener('click', () => toggleMenu(!menu.classList.contains('active')));
            overlay && overlay.addEventListener('click', () => toggleMenu(false));
        }

        const blogTrack = document.getElementById('blog-track');
        const blogCarousel = document.getElementById('blog-carousel');
        const blogDots = document.getElementById('blog-dots');
        if (blogTrack && blogCarousel && blogDots) {
            const cards = Array.from(blogTrack.querySelectorAll('.blog-card'));
            const prev = blogCarousel.querySelector('.blog-nav-prev');
            const next = blogCarousel.querySelector('.blog-nav-next');

            function cardStep() {
                const first = cards[0];
                if (!first) return 0;
                const styles = window.getComputedStyle(blogTrack);
                return first.getBoundingClientRect().width + parseFloat(styles.columnGap || styles.gap || 0);
            }

            function visibleCount() {
                const step = cardStep();
                return step ? Math.max(1, Math.round(blogTrack.clientWidth / step)) : 1;
            }

            function pages() {
                return Math.max(1, Math.ceil(cards.length / visibleCount()));
            }

            function currentPage() {
                const step = cardStep();
                return step ? Math.round(blogTrack.scrollLeft / (step * visibleCount())) : 0;
            }

            function renderDots() {
                const total = pages();
                blogDots.innerHTML = '';
                for (let i = 0; i < total; i++) {
                    const dot = document.createElement('button');
                    dot.type = 'button';
                    dot.className = 'blog-dot';
                    dot.setAttribute('aria-label', `Go to blog page ${i + 1}`);
                    dot.addEventListener('click', () => {
                        blogTrack.scrollTo({ left: i * cardStep() * visibleCount(), behavior: 'smooth' });
                    });
                    blogDots.appendChild(dot);
                }
                updateDots();
            }

            function updateDots() {
                const page = currentPage();
                blogDots.querySelectorAll('.blog-dot').forEach((dot, index) => {
                    dot.classList.toggle('active', index === page);
                });
            }

            prev && prev.addEventListener('click', () => {
                blogTrack.scrollBy({ left: -cardStep() * visibleCount(), behavior: 'smooth' });
            });
            next && next.addEventListener('click', () => {
                blogTrack.scrollBy({ left: cardStep() * visibleCount(), behavior: 'smooth' });
            });
            blogTrack.addEventListener('scroll', updateDots, { passive: true });
            window.addEventListener('resize', renderDots);
            renderDots();
        }
    </script>

    <!-- Chatbot Side Panel -->
    <div id="chatbot-widget" class="chatbot-widget">
        <div class="chatbot-toggle" id="chatbot-toggle">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
        </div>
        <div class="chatbot-panel" id="chatbot-panel">
            <div class="chatbot-header">
                <div>
                    <h3>SheenClassics Assistant</h3>
                    <p>Ask about products, orders, coupons, shipping, or cart help.</p>
                </div>
                <button class="chatbot-close" id="chatbot-close">&times;</button>
            </div>
            <div id="chat-history" class="chatbot-history" aria-live="polite" aria-atomic="false"></div>
            <form id="chat-form" class="chatbot-form">
                <input id="chat-input" type="text" placeholder="Type a question..." autocomplete="off" required>
                <button type="submit" class="btn btn-primary">Send</button>
            </form>
        </div>
    </div>

    <script src="/js/chatbot.js"></script>

    <%- include('partials/footer') %>
